+async def sync_tautulli_watch_data() -> None:
+    """
+    Enrich Movie and Series watch data (view_count, last_viewed_at, never_watched)
+    using Tautulli's playback history.  Tautulli typically has richer data than
+    Plex's built-in viewCount because it tracks every play event across all users.
+    """
+    tautulli = service_manager.tautulli
+    if not tautulli:
+        LOG.debug("No Tautulli service configured - skipping watch data sync")
+        return
+
+    async with track_task_execution(Task.SYNC_TAUTULLI_WATCH_DATA):
+        LOG.info("Syncing watch data from Tautulli...")
+
+        # fetch all movie history
+        movie_history = await tautulli.get_all_history(media_type="movie")
+        # fetch all episode history (aggregated to series level)
+        episode_history = await tautulli.get_all_history(media_type="episode")
+
+        # aggregate movie plays by rating_key → (play_count, last_played_timestamp)
+        movie_watch: dict[str, tuple[int, datetime | None]] = {}
+        for record in movie_history:
+            rk = str(record.get("rating_key", ""))
+            if not rk:
+                continue
+            ts = record.get("date") or record.get("started")
+            play_date: datetime | None = None
+            if ts:
+                try:
+                    play_date = datetime.fromtimestamp(int(ts), tz=timezone.utc)
+                except (ValueError, TypeError, OSError):
+                    pass
+            prev_count, prev_date = movie_watch.get(rk, (0, None))
+            new_count = prev_count + 1
+            if play_date and (prev_date is None or play_date > prev_date):
+                new_date = play_date
+            else:
+                new_date = prev_date
+            movie_watch[rk] = (new_count, new_date)
+
+        # aggregate episode plays to series level by grandparent_rating_key
+        series_watch: dict[str, tuple[int, datetime | None]] = {}
+        for record in episode_history:
+            rk = str(record.get("grandparent_rating_key", ""))
+            if not rk:
+                continue
+            ts = record.get("date") or record.get("started")
+            play_date: datetime | None = None  # noqa: F841
+            if ts:
+                try:
+                    play_date = datetime.fromtimestamp(int(ts), tz=timezone.utc)
+                except (ValueError, TypeError, OSError):
+                    pass
+            prev_count, prev_date = series_watch.get(rk, (0, None))
+            new_count = prev_count + 1
+            if play_date and (prev_date is None or play_date > prev_date):
+                new_date = play_date
+            else:
+                new_date = prev_date
+            series_watch[rk] = (new_count, new_date)
+
+        # update Movie rows where Tautulli has better data
+        if movie_watch:
+            async with async_db() as session:
+                # find movies whose versions have matching Plex rating keys
+                result = await session.execute(
+                    select(Movie, MovieVersion.service_item_id).join(
+                        MovieVersion, Movie.id == MovieVersion.movie_id
+                    )
+                )
+                updated = 0
+                for movie, service_item_id in result.all():
+                    if service_item_id not in movie_watch:
+                        continue
+                    tau_count, tau_lva = movie_watch[service_item_id]
+                    if tau_lva and tau_lva.tzinfo:
+                        tau_lva = tau_lva.replace(tzinfo=None)
+                    changed = False
+                    if tau_count > movie.view_count:
+                        movie.view_count = tau_count
+                        changed = True
+                    if tau_lva and (
+                        not movie.last_viewed_at or tau_lva > movie.last_viewed_at
+                    ):
+                        movie.last_viewed_at = tau_lva
+                        changed = True
+                    if changed:
+                        movie.never_watched = False
+                        updated += 1
+                await session.commit()
+                LOG.info(f"Updated watch data for {updated} movies from Tautulli")
+
+        # update Series rows
+        if series_watch:
+            async with async_db() as session:
+                # find series whose Plex service refs match
+                result = await session.execute(
+                    select(Series, SeriesServiceRef.service_id).join(
+                        SeriesServiceRef, Series.id == SeriesServiceRef.series_id
+                    )
+                )
+                updated = 0
+                for series, service_id in result.all():
+                    if service_id not in series_watch:
+                        continue
+                    tau_count, tau_lva = series_watch[service_id]
+                    if tau_lva and tau_lva.tzinfo:
+                        tau_lva = tau_lva.replace(tzinfo=None)
+                    changed = False
+                    if tau_count > series.view_count:
+                        series.view_count = tau_count
+                        changed = True
+                    if tau_lva and (
+                        not series.last_viewed_at or tau_lva > series.last_viewed_at
+                    ):
+                        series.last_viewed_at = tau_lva
+                        changed = True
+                    if changed:
+                        series.never_watched = False
+                        updated += 1
+                await session.commit()
+                LOG.info(f"Updated watch data for {updated} series from Tautulli")
